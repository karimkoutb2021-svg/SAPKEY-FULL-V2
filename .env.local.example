# ==============================
# SUPABASE — PUBLIC (in .env, committed)
# ==============================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ==============================
# SUPABASE — SECRETS (in .env.local, gitignored)
# ==============================
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ==============================
# OLD SUPABASE (for data migration scripts only)
# ==============================
OLD_SUPABASE_URL="https://old-project.supabase.co"
OLD_SUPABASE_KEY="old-service-role-key"

# ==============================
# CLOUDINARY — PUBLIC (in .env, committed)
# ==============================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# ==============================
# CLOUDINARY — SECRETS (in .env.local, gitignored)
# ==============================
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==============================
# APP CONFIG
# ==============================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SuperMarket ERP
NEXT_PUBLIC_DEFAULT_CURRENCY=SAR
NEXT_PUBLIC_DEFAULT_LANGUAGE=ar
